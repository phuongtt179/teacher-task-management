rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isPrincipal() {
      return isSignedIn() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'principal';
    }

    function isVicePrincipal() {
      return isSignedIn() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'vice_principal';
    }

    function isDepartmentHead() {
      return isSignedIn() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'department_head';
    }

    function isTeacher() {
      return isSignedIn() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    function isStaff() {
      return isSignedIn() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff';
    }

    function isVanThu() {
      return isSignedIn() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'van_thu';
    }

    // Whitelist collection
    match /whitelist/{email} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // App-wide feature flags (e.g. chat UI beta rollout)
    match /config/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      // Self-update allowed but cannot change own role; admin can change anything
      allow update: if isSignedIn() && (
        isAdmin() ||
        (request.auth.uid == userId &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
      );
      allow delete: if isAdmin();
    }

    // Tasks collection
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      // Văn thư chỉ được tạo (chuyển) công việc, không được sửa/xóa sau đó — xem update/delete bên dưới.
      allow create: if isVicePrincipal() || isAdmin() || isPrincipal() || isVanThu();
      // VP/Admin/Principal: full update. Teachers/dept heads: only update tasks assigned to them, only status+updatedAt fields
      allow update: if isVicePrincipal() || isAdmin() || isPrincipal() ||
                    (isSignedIn() &&
                     (isTeacher() || isDepartmentHead()) &&
                     resource.data.assignedTo.hasAny([request.auth.uid]) &&
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']));
      allow delete: if isVicePrincipal() || isAdmin() || isPrincipal();
    }

    // Submissions collection (top-level, not nested)
    match /submissions/{submissionId} {
      allow read: if isSignedIn();
      allow create: if isTeacher() || isVicePrincipal() || isAdmin() || isPrincipal() || isDepartmentHead();
      allow update: if isSignedIn() &&
                    (request.auth.uid == resource.data.teacherId ||
                     isVicePrincipal() ||
                     isAdmin() ||
                     isPrincipal());
      allow delete: if isVicePrincipal() || isAdmin() || isPrincipal();
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow delete: if isSignedIn() &&
                    (request.auth.uid == resource.data.userId || isAdmin());
    }

    // ==================== DOCUMENT MANAGEMENT ====================

    // School Years
    match /schoolYears/{yearId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() || isVicePrincipal() || isPrincipal();
    }

    // Document Types
    match /documentTypes/{typeId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() || isVicePrincipal() || isPrincipal();
    }

    // Document Categories
    match /documentCategories/{categoryId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() || isVicePrincipal() || isPrincipal();
    }

    // Document Sub-Categories
    match /documentSubCategories/{subCategoryId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() || isVicePrincipal() || isPrincipal();
    }

    // Departments
    match /departments/{departmentId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() || isVicePrincipal() || isPrincipal();
    }

    // Documents (file metadata)
    match /documents/{documentId} {
      // Helper to get category type
      function getCategoryType(categoryId) {
        return get(/databases/$(database)/documents/documentCategories/$(categoryId)).data.get('categoryType', 'personal');
      }

      function getRequestCategoryType() {
        return getCategoryType(request.resource.data.categoryId);
      }

      function getResourceCategoryType() {
        return getCategoryType(resource.data.categoryId);
      }

      // Helper to check if user is department head of a specific department
      function isDepartmentHeadOf(deptId) {
        return exists(/databases/$(database)/documents/departments/$(deptId)) &&
               get(/databases/$(database)/documents/departments/$(deptId)).data.headTeacherId == request.auth.uid;
      }

      // Helper to check if user is member of a department
      function isMemberOf(deptId) {
        return exists(/databases/$(database)/documents/departments/$(deptId)) &&
               get(/databases/$(database)/documents/departments/$(deptId)).data.memberIds.hasAny([request.auth.uid]);
      }

      // READ permissions: all signed-in users
      allow read: if isSignedIn();

      // CREATE permissions based on category type
      allow create: if isSignedIn() && (
        // Public documents: admin/VP/Principal can upload
        (getRequestCategoryType() == 'public' && (isAdmin() || isVicePrincipal() || isPrincipal())) ||

        // Personal documents: anyone can upload their own
        (getRequestCategoryType() == 'personal')
      );

      // UPDATE permissions: admin/VP/Principal, or the uploader editing their own document
      allow update: if isAdmin() || isVicePrincipal() || isPrincipal() ||
                    (isSignedIn() && resource.data.uploadedBy == request.auth.uid);

      // DELETE permissions: admin, VP, or Principal
      allow delete: if isAdmin() || isVicePrincipal() || isPrincipal();
    }

    // File Requests (delete/edit requests)
    match /fileRequests/{requestId} {
      // Users can read their own requests, or admin/vp/principal/dept head can read all
      allow read: if isSignedIn() &&
                  (resource.data.requestedBy == request.auth.uid ||
                   isAdmin() ||
                   isVicePrincipal() ||
                   isPrincipal() ||
                   isDepartmentHead());

      // Anyone can create requests
      allow create: if isSignedIn();

      // Admin/VP/Principal/dept head can approve/reject
      allow update: if isAdmin() || isVicePrincipal() || isPrincipal() || isDepartmentHead();

      // Only admin can delete
      allow delete: if isAdmin();
    }

    // Document Permissions
    match /documentPermissions/{permissionId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() || isVicePrincipal() || isPrincipal();
    }
  }
}
